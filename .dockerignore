# Exclude large weight files from build context (mount at runtime instead)
backend/weights/*.pt
backend/weights/*.pt.*
*.pt
*.pt.*

# Git and IDE
.git
.gitignore
.cursor
.vscode
*.swp
*~

# Python
__pycache__
*.py[cod]
*.egg-info
.eggs
.pytest_cache
.mypy_cache
*.so
.Python
venv
.venv
env

# Node (frontend – only backend context needs to be small when building backend)
node_modules
frontend/dist
frontend/node_modules

