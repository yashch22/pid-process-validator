# Database (defaults work with docker-compose)
DATABASE_URL=postgresql+asyncpg://piduser:pidpass@localhost:5432/pid_db
DATABASE_URL_SYNC=postgresql://piduser:pidpass@localhost:5432/pid_db

# Storage
PID_UPLOAD_DIR=data/uploads/pid
SOP_UPLOAD_DIR=data/uploads/sop
CHROMA_PERSIST_DIR=data/chroma

# Optional: override backend root (default: parent of app/)
# PID_GRAPH_ROOT=/path/to/backend

# Gemini for SOP ingestion and validation (required for full SOP/validate flow)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Optional: YOLO weights path (default: use pid_graph default)
# YOLO_WEIGHTS_PATH=backend/weights/best.pt
